# Caddyfile — reverse proxy for Nuxt 4
#
# Caddy automatically provisions and renews TLS certificates.
# Place at: /etc/caddy/Caddyfile  (or import from your global Caddyfile)
#
# Usage:
#   caddy validate --config Caddyfile
#   caddy run --config Caddyfile
#
# Assumes the Nuxt app container is running on localhost:3000.

example.com, www.example.com {
    # Automatic HTTPS via Let's Encrypt
    tls your@email.com

    # Security headers
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        -Server
    }

    # Health check — log suppressed
    handle /api/health {
        reverse_proxy localhost:3000 {
            header_up Host {upstream_hostport}
            header_up X-Forwarded-Host {host}
        }
        log {
            output discard
        }
    }

    # All requests — proxy to Nuxt/Nitro
    handle {
        reverse_proxy localhost:3000 {
            header_up Host {upstream_hostport}
            header_up X-Forwarded-Host {host}
            header_up X-Real-IP {remote_host}

            # Health check for upstream
            health_uri /api/health
            health_interval 30s
            health_timeout 10s
        }
    }

    # Enable compression
    encode zstd gzip

    # Logging
    log {
        output file /var/log/caddy/nuxt4-app.log {
            roll_size 100mb
            roll_keep 5
        }
        format json
    }
}
