{
  "name": "nuxt4-boilerplate",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "build:static": "nuxt generate",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare",
    "prepare": "husky",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck",
    "ci:check": "npm run lint && npm run typecheck",
    "commit": "git-cz",
    "release": "npm version",
    "docker:build": "docker build -t nuxt4-boilerplate .",
    "docker:run": "docker run -p 3000:3000 --env-file .env nuxt4-boilerplate"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue,mjs,cjs}": [
      "eslint --fix",
      "eslint"
    ]
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^1.12.0",
    "@nuxt/image": "^1.9.0",
    "@nuxt/ui": "^3.0.2",
    "@nuxtjs/i18n": "^9.5.5",
    "@nuxtjs/robots": "^5.0.0",
    "@nuxtjs/sitemap": "^6.0.0",
    "@pinia/nuxt": "^0.10.1",
    "@vite-pwa/nuxt": "^1.0.0",
    "nuxt": "^3.17.1",
    "pinia": "^3.0.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@nuxt/devtools": "latest",
    "@nuxt/eslint": "^1.3.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.8.3",
    "vue-tsc": "^2.2.10"
  }
}
