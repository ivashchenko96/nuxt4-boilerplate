# =============================================================================
# nuxt4-boilerplate — environment variable reference
# =============================================================================
# Copy this file to .env (local dev) or .env.local (docker-compose dev)
# NEVER commit a populated .env file.  Secrets must be injected at runtime
# via your hosting platform, CI/CD secrets manager, or Docker environment.
#
# Naming conventions:
#   NUXT_PUBLIC_*  — exposed to client bundle (safe to be public)
#   <plain name>   — server-only; never reaches the browser
# =============================================================================

# -----------------------------------------------------------------------------
# Application identity
# -----------------------------------------------------------------------------
NUXT_PUBLIC_APP_NAME="Enterprise Platform"
NUXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# API / backend
# -----------------------------------------------------------------------------
# Base URL for your REST API (public — used by client-side fetches)
NUXT_PUBLIC_API_BASE_URL="http://localhost:3001"

# Base URL for the authentication service (public — used by auth plugin)
NUXT_PUBLIC_AUTH_BASE_URL="http://localhost:3001"

# -----------------------------------------------------------------------------
# Server-only secrets  ⚠️  Never prefix these with NUXT_PUBLIC_
# -----------------------------------------------------------------------------
# Used for signing server-side operations; inject via secrets manager in prod
JWT_SECRET="change-me-in-production"
API_SECRET="change-me-in-production"

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
NUXT_PUBLIC_ENABLE_PWA="true"
NUXT_PUBLIC_ENABLE_SEO="true"

# -----------------------------------------------------------------------------
# Multi-tenancy
# -----------------------------------------------------------------------------
NUXT_PUBLIC_DEFAULT_TENANT="default"

# -----------------------------------------------------------------------------
# Nitro / server runtime
# (only needed when running `node .output/server/index.mjs` directly)
# -----------------------------------------------------------------------------
# NITRO_PORT=3000
# NITRO_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Node environment
# (set automatically by most platforms; override here for local parity testing)
# -----------------------------------------------------------------------------
# NODE_ENV=production

# =============================================================================
# Environment-specific guidance
# =============================================================================
# Local dev   → copy to .env and fill in values
# Docker dev  → copy to .env.local (referenced by docker-compose.yml)
# Staging     → set vars in your hosting platform / CI secrets
# Production  → NEVER use .env files; use the platform's secret injection
#               (Vercel env vars, AWS Secrets Manager, Kubernetes Secrets, etc.)
# =============================================================================

